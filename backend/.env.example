# ------------------------------------------------------------
#  Copia este archivo como  .env  y rellena tu clave.
# ------------------------------------------------------------

# Clave de la API de Anthropic (para leer las facturas con visión).
# Consíguela en: https://console.anthropic.com  -> API Keys
# Si la dejas vacía, el extractor funciona en MODO DEMO.
ANTHROPIC_API_KEY=

# Modelo a usar. Opciones: claude-sonnet-5 (preciso) o
# claude-haiku-4-5-20251001 (más barato y rápido).
ANTHROPIC_MODEL=claude-sonnet-5
